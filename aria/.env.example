# ── Required ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...                 # your OpenAI API key

# ── Email (Gmail example) ────────────────────────────────────────────────────
EMAIL_ADDRESS=you@gmail.com
EMAIL_PASSWORD=your-app-password      # Gmail → Security → App Passwords

# IMAP (read)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# SMTP (send)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

EMAIL_FETCH_LIMIT=10                  # max emails to fetch at once

# ── LLM tuning ───────────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini              # or gpt-4o, gpt-3.5-turbo, etc.
AGENT_TEMPERATURE=0.2
AGENT_MAX_ITERATIONS=10

# ── Optional: SerpAPI for Google search (leave blank to use DuckDuckGo) ──────
SERPAPI_KEY=

# ── Server ───────────────────────────────────────────────────────────────────
ARIA_HOST=0.0.0.0
ARIA_PORT=8000
ARIA_DEBUG=false
